# Core app
FTMCP_APP_VERSION=0.1.0
FTMCP_TAX_YEAR=FY 2025-26

# Storage
FTMCP_DB_PATH=./data/freelance_tax.db
FTMCP_INVOICE_DIR=./invoices

# Defaults and limits
FTMCP_DEFAULT_GST_RATE=18
FTMCP_RATE_LIMIT_PER_MIN=120

# Auth mode
FTMCP_ENABLE_AUTH=false

# OAuth 2.1 (enable when auth is implemented)
FTMCP_OAUTH_ISSUER=https://auth.yourdomain.com
FTMCP_OAUTH_AUDIENCE=freelance-tax-mcp
FTMCP_OAUTH_JWKS_URL=https://auth.yourdomain.com/.well-known/jwks.json
FTMCP_OAUTH_CLIENT_ID=
FTMCP_OAUTH_CLIENT_SECRET=
FTMCP_OAUTH_REDIRECT_URI=https://yourapp.com/oauth/callback

# Optional AI providers (for LLM-based assistant flows)
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# Planned external tax data providers
GST_PROVIDER_BASE_URL=
GST_PROVIDER_API_KEY=
INCOME_TAX_PROVIDER_BASE_URL=
INCOME_TAX_PROVIDER_API_KEY=

# Reminder delivery (email/sms/webhook worker)
FTMCP_REMINDER_PROVIDER=webhook
FTMCP_REMINDER_WEBHOOK_URL=
FTMCP_REMINDER_WEBHOOK_SECRET=
